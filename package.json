{
  "name": "driver-manager-db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker API for Driver Manager with D1 database",
  "main": "worker.js",
  "scripts": {
    "security:verify-deploy": "node scripts/verify-security-deploy-config.mjs",
    "dashboard:sync-assets": "node scripts/sync-dashboard-assets.mjs",
    "dev": "npm run dashboard:sync-assets && wrangler dev",
    "dev:remote": "npm run dashboard:sync-assets && wrangler dev --remote",
    "deploy": "npm run security:verify-deploy && npm run dashboard:sync-assets && wrangler deploy",
    "tail": "wrangler tail",
    "test:dashboard-embed": "node --test tests_js/dashboard.embed.test.mjs",
    "test:worker": "node --test tests_js/worker.contract.test.mjs",
    "test:sse:tenants": "node scripts/test-sse-tenants.mjs",
    "users:tenant": "python scripts/manage_tenant_users.py",
    "test:web": "npm run test:dashboard-embed && npm run test:worker",
    "d1:migrate": "wrangler d1 migrations apply driver-manager-db",
    "d1:migrate:remote": "wrangler d1 migrations apply driver-manager-db --remote",
    "d1:studio": "wrangler d1 execute driver-manager-db --local --command=\"SELECT 1;\"",
    "users:sync:r2-to-d1": "python sync_r2_users_to_web_d1.py"
  },
  "devDependencies": {
    "chart.js": "^4.4.1",
    "jsdom": "^28.1.0",
    "qrcode-generator": "^1.4.4",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
