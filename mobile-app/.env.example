EXPO_PUBLIC_API_BASE_URL=https://your-worker-name.your-subdomain.workers.dev
APP_DISPLAY_NAME=SiteOps
EXPO_PUBLIC_ENABLE_REMOTE_OCR_FALLBACK=false
EXPO_PUBLIC_OCR_STRICT_REVIEW=true
EXPO_PUBLIC_OCR_LOW_CONFIDENCE_THRESHOLD=0.72

# Seguridad mobile:
# - No incluyas EXPO_PUBLIC_API_TOKEN ni EXPO_PUBLIC_API_SECRET en app distribuida.
# - Autenticar via /web/auth/login y usar Bearer de sesion corta.
